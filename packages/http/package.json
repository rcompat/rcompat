{
  "name": "@rcompat/http",
  "version": "0.27.1",
  "description": "Standard library HTTP",
  "bugs": "https://github.com/rcompat/rcompat/issues",
  "license": "MIT",
  "files": [
    "/lib/**/*.js",
    "/lib/**/*.d.ts",
    "!/**/*.spec.*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rcompat/rcompat",
    "directory": "packages/http"
  },
  "scripts": {
    "build": "npm run clean && tsc",
    "test": "npx proby",
    "clean": "rm -rf ./lib",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "undici-types": "8.0.2"
  },
  "dependencies": {
    "@rcompat/assert": "workspace:^",
    "@rcompat/dict": "workspace:^",
    "@rcompat/fn": "workspace:^",
    "@rcompat/fs": "workspace:^",
    "@rcompat/type": "workspace:^",
    "busboy": "^1.6.0",
    "ws": "^8.20.0"
  },
  "type": "module",
  "imports": {
    "#serve": {
      "@rcompat/source": "./src/private/serve/node.ts",
      "bun": "./lib/private/serve/bun.js",
      "deno": "./lib/private/serve/deno.js",
      "node": "./lib/private/serve/node.js"
    },
    "#*": {
      "@rcompat/source": "./src/private/*.ts",
      "default": "./lib/private/*.js"
    }
  },
  "exports": {
    ".": {
      "@rcompat/source": "./src/public/index.ts",
      "default": "./lib/public/index.js"
    },
    "./*": {
      "@rcompat/source": "./src/public/*.ts",
      "default": "./lib/public/*.js"
    }
  }
}
