{
  "name": "@rcompat/runtime",
  "version": "0.12.0",
  "description": "Standard library runtime context",
  "bugs": "https://github.com/rcompat/rcompat/issues",
  "license": "MIT",
  "files": [
    "/lib/**/*.js",
    "/lib/**/*.d.ts",
    "!/**/*.spec.*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rcompat/rcompat",
    "directory": "packages/runtime"
  },
  "scripts": {
    "build": "npm run clean && tsc",
    "test": "npx proby",
    "clean": "rm -rf ./lib",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@rcompat/fs": "workspace:^",
    "@rcompat/type": "workspace:^"
  },
  "type": "module",
  "imports": {
    "#*": {
      "@rcompat/source": "./src/public/*.ts",
      "default": "./lib/public/*.js"
    }
  },
  "exports": {
    ".": {
      "@rcompat/source": "./src/public/node.ts",
      "browser": "./lib/public/browser.js",
      "bun": "./lib/public/bun.js",
      "deno": "./lib/public/deno.js",
      "node": "./lib/public/node.js",
      "default": "./lib/public/node.js"
    }
  }
}
